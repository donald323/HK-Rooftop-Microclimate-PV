{
  "description": "Data extraction configuration for creating analysis-ready datasets",
  "input_directory": "../data/downsampled",
  "interpolated_directory": "../data/interpolated", 
  "output_directory": "../data/extracted",
  "settings": {
    "date_range": {
      "start_date": "2024-04-01",
      "end_date": "2025-10-01",
      "description": "Default date range for data extraction",
      "format": "YYYY-MM-DD"
    },
    "output_options": {
      "include_metadata": true,
      "preserve_Azginal_columns": false,
      "timestamp_column": "DateTime"
    }
  },
  "power": {
    "description": "Extract power data from all optimizer channels",
    "files": [
      {
        "input": "power/power_merged.csv",
        "output": "power/PV_Power.csv",
        "columns": {
          "DateTime": "DateTime",
          "Optimizer 2.2.20- Production - Power (W)": "PV_PVR_1_Az243_Ang10_Hgt096",
          "Optimizer 2.2.21- Production - Power (W)": "PV_PVR_1_Az242_Ang10_Hgt096_SenTree",
          "Optimizer 2.2.13- Production - Power (W)": "PV_PVR_1_Az60_Ang10_Hgt096",
          "Optimizer 2.2.12- Production - Power (W)": "PV_PVR_1_Az66_Ang10_Hgt096",
          "Optimizer 2.4.14- Production - Power (W)": "PV_nrWT_1_Az170_Ang10_Hgt095",
          "Optimizer 2.4.15- Production - Power (W)": "PV_nrWT_1_Az171_Ang10_Hgt095",
          "Optimizer 2.4.16- Production - Power (W)": "PV_nrWT_1_Az352_Ang10_Hgt095",
          "Optimizer 2.4.17- Production - Power (W)": "PV_nrWT_1_Az351_Ang10_Hgt095",
          "Optimizer 2.4.22- Production - Power (W)": "PV_nrWT_1_Az172_Ang10_Hgt095",
          "Optimizer 2.5.8- Production - Power (W)": "PV_nrSed_Az179_Ang22_Hgt092_Land_Shd",
          "Optimizer 2.5.9- Production - Power (W)": "PV_nrSed_Az180_Ang22_Hgt092_Land",
          "Optimizer 2.5.21- Production - Power (W)": "PV_nrZoy_Az181_Ang22_Hgt092_Land",
          "Optimizer 2.5.22- Production - Power (W)": "PV_nrZoy_Az182_Ang22_Hgt092_Land_Shd",
          "Optimizer 2.5.14- Production - Power (W)": "PV_nrSed_Az180_Ang10_Hgt094_Vert",
          "Optimizer 2.5.15- Production - Power (W)": "PV_nrSed_Az181_Ang10_Hgt094_Vert",
          "Optimizer 2.5.16- Production - Power (W)": "PV_nrZoy_Az182_Ang10_Hgt094_Vert",
          "Optimizer 2.5.17- Production - Power (W)": "PV_nrZoy_Az183_Ang10_Hgt094_Vert",
          "Optimizer 1.8.1- Production - Power (W)": "PV_Lift2_Az319_Ang1_Hgt083",
          "Optimizer 1.8.2- Production - Power (W)": "PV_Lift2_Az320_Ang1_Hgt083",
          "Optimizer 3.2.1- Production - Power (W)": "WT_Az180_Ang22_Hgt060",
          "Optimizer 3.2.2- Production - Power (W)": "WT_Az180_Ang3_Hgt090",
          "Optimizer 3.2.3- Production - Power (W)": "WT_Az180_Ang3_Hgt060",
          "Optimizer 3.2.4- Production - Power (W)": "WT_Az180_Ang12_Hgt060",
          "Optimizer 2.6.15- Production - Power (W)": "WT_Az180_Ang12_Hgt090",
          "Optimizer 2.6.16- Production - Power (W)": "WT_Az180_Ang22_Hgt090",
          "Optimizer 2.6.17- Production - Power (W)": "WT_Az180_Ang22_Hgt075",
          "Optimizer 2.6.18- Production - Power (W)": "WT_Az180_Ang12_Hgt075",
          "Optimizer 2.5.10- Production - Power (W)": "Sed_Az180_Ang22_Hgt060",
