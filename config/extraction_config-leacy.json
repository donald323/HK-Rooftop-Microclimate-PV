          }
        }
      },
      {
        "input": "weather/dev9010F240100001.csv",
        "output": "weather/PVIGR_WedTri_12deg.csv",
        "columns": {
          "DateTime": "DateTime",
          "Temp_1 []": "Ta_050cm_PVHgt_090cm",
          "Temp_2 []": "Ta_050cm_PVHgt_075cm",
          "Humi_1 []": "RH_050cm_PVHgt_090cm",
