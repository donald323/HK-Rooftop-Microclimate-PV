  "soil_moisture": {
    "description": "Extract soil moisture data from three sensors",
    "files": [
      {
        "input": "weather/dev9010E231200001.csv",
        "output": "soil moisture/PVIGR_SoilMoisture.csv",
        "columns": {
          "DateTime": "DateTime",
          "SoilMoisture_1 []": "SM_Sedum_PVHgt_060cm",
          "SoilMoisture_2 []": "SM_Zoysia_PVHgt_090cm"
        },
        "merge_from": {
          "input": "weather/dev9010F240100002.csv",
          "columns": {
            "SoilMoisture []": "SM_WedTri_PVHgt_060cm"
          }
        }
      }
    ]
  },
  "surface_temp": {
    "description": "Extract surface temperature (thermocouple) data",
    "files": [
      {
        "input": "weather/Lib_GR.csv",
        "output": "surface temperature/GR.csv",
        "columns": {
          "DateTime": "DateTime",
          "TC_Temp1": "Tsoil1",
          "TC_Temp2": "Tsoil2",
          "TC_Temp3": "Tsoil3"
        }
      },
      {
        "input": "weather/PV_Lift3.csv",
        "output": "surface temperature/PVR_2.csv",
        "columns": {
          "DateTime": "DateTime",
          "TC_Temp1": "TR",
          "TC_Temp2": "TPV_b",
          "TC_Temp3": "TPV_a"
        }
      },
      {
        "input": "weather/dev9010C231200001.csv",
        "output": "surface temperature/PVIGR_Zoysia.csv",
        "columns": {
          "DateTime": "DateTime",
          "TC1_Temp []": "TPV_a_PVHgt_090cm",
          "TC2_Temp []": "Tsoil_PVHgt_090cm",
          "TC3_Temp []": "TPV_a_PVHgt_060cm",
          "TC4_Temp []": "TPV_b_PVHgt_060cm"
        },
        "merge_from": {
          "input": "weather/dev9010E231200001.csv",
          "columns": {
            "TC1_Temp []": "TPV_b_PVHgt_090cm"
          }
        }
      },
      {
        "input": "weather/dev9010E231200001.csv",
        "output": "surface temperature/PVIGR_Sedum.csv",
        "columns": {
          "DateTime": "DateTime",
          "TC2_Temp []": "TPV_a_PVHgt_090cm",
          "TC4_Temp []": "TPV_b_PVHgt_090cm",
          "TC5_Temp []": "TPV_a_PVHgt_060cm",
          "TC6_Temp []": "TPV_b_PVHgt_060cm"
        }
      },
      {
        "input": "weather/dev9010D231200001.csv",
        "output": "surface temperature/BRwithHVAC.csv",
        "columns": {
          "DateTime": "DateTime",
          "Temp_1 []": "TR"
        }
      },
      {
        "input": "weather/dev9010b231200001.csv",
        "output": "surface temperature/PVIGR_WedTri_22deg.csv",
        "columns": {
          "DateTime": "DateTime",
          "TC1_Temp []": "TPV_a_PVHgt_060cm",
          "TC2_Temp []": "TPV_b_PVHgt_060cm",
          "TC3_Temp []": "Tsoil_PVHgt_060cm"
        },
        "merge_from": {
          "input": "weather/dev9010F240100001.csv",
