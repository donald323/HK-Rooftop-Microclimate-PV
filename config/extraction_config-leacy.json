        "columns": {
          "DateTime": "DateTime",
          "Temp_1 []": "Ta_180cm",
          "Temp_2 []": "Ta_050cm",
          "Humi_1 []": "RH_180cm",
          "Humi_2 []": "RH_050cm",
          "Met_Speed_1 []": "Ws_200cm",
          "Met_Dir_1 []": "Wdir_200cm"
        }
      },
      {
        "input": "weather/dev9010b231200001.csv",
