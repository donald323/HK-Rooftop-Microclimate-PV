  "weather": {
    "description": "Extract weather data (temperature, humidity, wind, irradiance)",
    "files": [
      {
        "input": "weather/Lib_GR.csv",
        "output": "weather/GR.csv",
        "columns": {
          "DateTime": "DateTime",
          "Temp2": "Ta_180cm",
          "Temp1": "Ta_050cm",
          "Humi2": "RH_180cm",
          "Humi1": "RH_050cm",
          "Met_Speed1": "Ws_200cm",
          "Met_Dir1": "Wdir_200cm"
        }
      },
      {
        "input": "weather/PV_Lift3.csv",
        "output": "weather/PVR_2.csv",
        "columns": {
          "DateTime": "DateTime",
          "Temp1": "Ta_180cm",
          "Temp2": "Ta_050cm",
          "Humi1": "RH_180cm",
          "Humi2": "RH_050cm",
          "Met_Speed1": "Ws_200cm",
          "Met_Dir1": "Wdir_200cm",
          "Met_Speed2": "Ws_050cm",
          "Met_Dir2": "Wdir_050cm"
