            "TC1_Temp []": "TPV_a_PVHgt_090cm",
            "TC2_Temp []": "TPV_b_PVHgt_090cm",
            "TC6_Temp []": "TPV_a_PVHgt_075cm",
            "TC7_Temp []": "TPV_b_PVHgt_075cm"
          }
        }
      },
      {
        "input": "weather/dev9010F240100001.csv",
