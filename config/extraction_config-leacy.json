      {
        "input": "weather/dev9010F240100002.csv",
        "output": "weather/PVIGR_WedTri_3deg.csv",
        "columns": {
          "DateTime": "DateTime",
          "Temp_1 []": "Ta_050cm_PVHgt_090cm",
          "Temp_2 []": "Ta_050cm_PVHgt_060cm",
          "Humi_1 []": "RH_050cm_PVHgt_090cm",
          "Humi_2 []": "RH_050cm_PVHgt_060cm"
