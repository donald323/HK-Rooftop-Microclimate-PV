        "columns": {
          "DateTime": "DateTime",
          "TC3_Temp []": "TPV_a_PVHgt_090cm",
          "TC4_Temp []": "TPV_a_PVHgt_075cm",
          "TC5_Temp []": "TPV_b_PVHgt_075cm"
        },
        "merge_from": [
          {
            "input": "weather/dev9010F240100002.csv",
            "columns": {
              "TC6_Temp []": "TPV_a_PVHgt_060cm",
              "TC7_Temp []": "TPV_b_PVHgt_060cm"
